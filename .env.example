APP_ENV=development
INGESTION_PORT=8000
INGESTION_API_KEY=change-this-local-api-key
# Bot tokens are no longer a single static value -- each installing
# workspace gets its own via the OAuth install flow (issue #61), stored
# encrypted in slack_installations. Slack traffic (events, slash commands,
# interactivity, OAuth install/redirect) is served over HTTP (issue #62),
# not Socket Mode -- there is no SLACK_APP_TOKEN anymore.
# From your Slack app's "Basic Information" page (Distribution must be
# enabled to see client_id/client_secret).
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_PORT=3000
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=your-fernet-key
SLACK_TOKEN_VERIFICATION_ENABLED=false
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_KEY=your-supabase-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBED_MODEL=voyage-3.5-lite
VOYAGE_EMBED_DIMENSION=1024
WORKSPACE_ID=your-slack-workspace-id
# Google Drive/Docs/Sheets use one shared Google account. Put the OAuth
# "Desktop app" client_secret.json in the repo root, then run
# `python -m tools.google_auth_bootstrap` once -- it opens a browser for
# consent and writes the token below. Override the path if you like.
GOOGLE_TOKEN_PATH=secrets/club_token.json
DRIVE_POLL_INTERVAL_SECONDS=300
# Local-dev only: token for the `ngrok` service in docker-compose.yml that
# gives Slack a public HTTPS URL to reach the bot. Get it from
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken
# Who can manage connected Drive folders / confirm reconciliation proposals
# is per-workspace now (issue #67, workspace_admin_settings table), seeded
# automatically with the installer -- no env var needed here anymore.
ANTHROPIC_API_KEY=your-anthropic-api-key
